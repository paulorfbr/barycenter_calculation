# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

# If JAVA_HOME is not set, try to find Java on the PATH
if [ -z "$JAVA_HOME" ]; then
  JAVA_EXECUTABLE="$(which java 2>/dev/null)"
  if [ -n "$JAVA_EXECUTABLE" ]; then
    JAVA_HOME="$(dirname "$(dirname "$(readlink -f "$JAVA_EXECUTABLE")")")"
  fi
fi

# Maven wrapper download
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"
MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  # Download wrapper jar using Java
  DISTRIBUTION_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')
  WRAPPER_JAR_URL=$(grep wrapperUrl "$MAVEN_WRAPPER_PROPERTIES" | sed 's/wrapperUrl=//')

  echo "Downloading Maven Wrapper..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_JAR_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_JAR_URL"
  else
    echo "Neither curl nor wget is available. Cannot download Maven Wrapper."
    exit 1
  fi
fi

exec "$JAVA_HOME/bin/java" \
  -jar "$MAVEN_WRAPPER_JAR" \
  -Dmaven.multiModuleProjectDirectory="$PWD" \
  "$@"
