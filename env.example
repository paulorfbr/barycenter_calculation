# =============================================================================
# Environment Configuration Template
# Copy this file to .env and customize for your environment
# =============================================================================

# Build Information
VERSION=1.0.0
BUILD_DATE=2026-03-18T00:00:00Z
GIT_COMMIT=main
GIT_BRANCH=main

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Database Configuration
POSTGRES_PASSWORD=secure_postgres_password
POSTGRES_USER=logistics
COMPANY_DB_PASSWORD=company_secure_pass
SITE_DB_PASSWORD=site_secure_pass
CALC_DB_PASSWORD=calc_secure_pass

# Redis Configuration
REDIS_PASSWORD=secure_redis_password

# Kafka Configuration
KAFKA_HEAP_OPTS=-Xmx512m -Xms512m

# Monitoring Configuration
GRAFANA_PASSWORD=admin_secure_password

# Application Configuration
CORS_ALLOWED_ORIGIN=http://localhost:4200

# JVM Configuration
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=70.0 -XX:+ExitOnOutOfMemoryError

# Logging Configuration
LOG_LEVEL=INFO
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %msg%n

# Security Configuration
JWT_SECRET=your-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# External Services
API_GATEWAY_URL=http://api-gateway:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8085

# Development Tools (only for development environment)
ENABLE_DEBUG_TOOLS=true
ENABLE_HOT_RELOAD=true
SKIP_SSL_VERIFICATION=false

# Production Settings (override for production)
SPRING_PROFILES_ACTIVE=development
SERVER_PORT=8080
MANAGEMENT_SERVER_PORT=8090

# Container Resource Limits
MEMORY_LIMIT=1g
CPU_LIMIT=1.0
MEMORY_RESERVATION=512m
CPU_RESERVATION=0.5
