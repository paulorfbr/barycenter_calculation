# =============================================================================
# Environment variable template for local development.
# Copy this file to .env and fill in the values before running Docker Compose.
# NEVER commit .env to source control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=logistics
POSTGRES_PASSWORD=dev_password_change_me

# --- Service DB passwords (must match init-databases.sql) ---
COMPANY_DB_PASSWORD=company_pass
SITE_DB_PASSWORD=site_pass
CALC_DB_PASSWORD=calc_pass

# --- Redis ---
REDIS_PASSWORD=

# --- Grafana ---
GRAFANA_PASSWORD=admin

# --- CORS: Angular dev server origin ---
CORS_ALLOWED_ORIGIN=http://localhost:4200

# --- Tracing ---
TRACING_SAMPLE_RATE=1.0

# --- Build metadata (set by CI/CD pipeline) ---
BUILD_DATE=local
GIT_COMMIT=local
GIT_BRANCH=local
VERSION=dev
