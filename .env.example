# =============================================================================
# Environment Variables Template
#
# Copy this file to .env for local development.
# NEVER commit .env to version control.
#
# For CI/CD, set these as protected GitLab CI/CD variables
# (Settings > CI/CD > Variables) with appropriate masking.
# =============================================================================

# ---- AWS Credentials (CI deployer IAM user) ---------------------------------
# Scope: package + deploy stages in .gitlab-ci.yml
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=eu-west-1

# ---- ECR Registry ----------------------------------------------------------
ECR_REGISTRY=123456789012.dkr.ecr.eu-west-1.amazonaws.com
ECR_REPOSITORY=logistics-api

# ---- Terraform Remote State ------------------------------------------------
TF_STATE_BUCKET=my-org-logistics-tfstate
TF_STATE_LOCK_TABLE=my-org-logistics-tflock

# ---- Environment-specific --------------------------------------------------
# ACM certificate ARN (required for staging and prod HTTPS listeners)
# Leave empty for dev (HTTP-only)
TF_VAR_certificate_arn=arn:aws:acm:eu-west-1:123456789012:certificate/...

# Alarm notification email
TF_VAR_alarm_email=ops-team@your-company.com

# AWS account ID (used in Terraform modules for scoped IAM policies)
TF_VAR_aws_account_id=123456789012

# CI IAM role ARNs that can push to ECR (comma-separated in Terraform list syntax)
# TF_VAR_ci_role_arns='["arn:aws:iam::123456789012:user/gitlab-ci"]'

# ---- Local Docker Compose --------------------------------------------------
BUILD_DATE=local
GIT_COMMIT=local
GIT_BRANCH=local
VERSION=dev
